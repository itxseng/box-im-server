<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bx.implatform.mapper.ChatSeePermissionMapper">

    <insert id="insertBatchSomeColumn">
        INSERT INTO chat_see_permission (
        user_id,
        target_id,
        permission_type
        )
        VALUES
        <foreach collection="list" item="item" index="index" separator=",">
            (
            #{item.userId},
            #{item.targetId},
            #{item.permissionType}
            )
        </foreach>
    </insert>
</mapper>
